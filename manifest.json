{
  "manifest_version": 3,
  "name": "精力管理可视化 (Energy Manager)",
  "version": "1.0",
  "description": "可视化精力管理，像玩游戏一样管理你的每一天。",
  "permissions": ["storage", "alarms", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "精力管理"
  },
  "background": {
    "service_worker": "background.js"
  }
}