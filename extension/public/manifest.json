{
  "manifest_version": 3,
  "name": "精力管理可视化",
  "version": "1.0",
  "description": "游戏化管理你的精力和日常习惯。",
  "permissions": ["storage", "alarms"],
  "action": {
    "default_popup": "extension/pages/popup/index.html",
    "default_title": "精力管理"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
